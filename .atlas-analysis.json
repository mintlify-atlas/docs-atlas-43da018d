  "keyFeatures": [
    "Package manager agnostic (works with pnpm, bun, and npm)",
    "Monorepo-aware installs with automatic scoping",
    "Workspace package navigation with shell integration",
    "Paste-friendly command parsing",
    "Native binary with fast shell completions"
  ],
  "publicApiSurface": [
    "pm i - Install dependencies",
    "pm add - Add packages",
    "pm remove - Remove packages",
    "pm run - Run package scripts",
    "pm pls - List workspace packages",
    "pm cd - Navigate to workspace packages",
    "pm ls - Proxy to package manager ls",
    "pm up/update - Update dependencies",
    "pm link - Link packages",
    "pm unlink - Unlink packages",
    "pm why - Show dependency reasons",
    "pm x - Execute packages",
    "pm activate - Setup shell integration"
  ]
